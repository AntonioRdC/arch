[global]
    font = JetBrainsMono Nerd Font 10
    frame_width = 1
    frame_color = "#89b4fa"
    separator_color = frame
    highlight = "#89b4fa"
    corner_radius = 8
    origin = top-right
    offset = (12, 48)
    padding = 12
    horizontal_padding = 12
    icon_theme = Tela-circle-dracula
    enable_recursive_icon_lookup = true

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 4

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 6

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#fab387"
    timeout = 0
